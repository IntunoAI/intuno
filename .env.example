# ── Intuno Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ── Authentication ────────────────────────────────────────────────────────────
# [REQUIRED] Secret key for signing JWT tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# JWT token expiration in minutes (default: 10080 = 7 days)
# JWT_EXPIRATION_MINUTES=10080

# ── OpenAI ────────────────────────────────────────────────────────────────────
# [REQUIRED] Used for embeddings (text-embedding-3-small) and LLM features
OPENAI_API_KEY=

# Embedding model (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small

# LLM model for agent enhancement and planning (default: gpt-4o-mini)
# LLM_ENHANCEMENT_MODEL=gpt-4o-mini
# PLANNER_LLM_MODEL=gpt-4o-mini
# BRAND_AGENT_LLM_MODEL=gpt-4o-mini

# ── Vector Database (Qdrant) ──────────────────────────────────────────────────
# Qdrant connection (default: http://localhost:6333)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection for caching (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# Dashboard cache TTL in seconds (default: 120, 0 = no cache)
# DASHBOARD_CACHE_TTL=120

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional: required only for brand verification emails
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=Intuno

# ── Security ──────────────────────────────────────────────────────────────────
# Encryption key for per-agent credentials (defaults to JWT_SECRET_KEY-derived)
# CREDENTIALS_ENCRYPTION_KEY=

# CORS origins (comma-separated, default: * for development)
# CORS_ORIGINS=["https://yourdomain.com"]

# SSRF protection: comma-separated allowed host patterns for agent invoke endpoints
# INVOKE_ENDPOINT_ALLOWED_HOSTS=*.example.com

# ── Application ───────────────────────────────────────────────────────────────
# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Enable LLM-enhanced agent descriptions on registration (default: true)
# ENABLE_LLM_ENHANCEMENT=true

# Use LLM for multi-step task planning (default: false)
# PLANNER_USE_LLM=false

# ── Economy ───────────────────────────────────────────────────────────────────
# Welcome bonus credits for new wallets (default: 500)
# ECONOMY_WELCOME_BONUS_CREDITS=500

# Credit packages (JSON array)
# ECONOMY_CREDIT_PACKAGES=[{"id":"starter","credits":500,"price_cents":500,"label":"$5"}]

# ── Workflow ──────────────────────────────────────────────────────────────────
# WORKFLOW_CONTEXT_BUS_TTL_SECONDS=86400
# WORKFLOW_DEFAULT_MAX_DURATION_SECONDS=300
# WORKFLOW_DEFAULT_MAX_CONCURRENT_EXECUTIONS=5
